// ParBase - Golf Subscription Platform
// Prisma Schema for Supabase (PostgreSQL)

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── USER ROLES ────────────────────────────────────────────────

enum Role {
  SUBSCRIBER
  ADMIN
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  PAST_DUE
}

enum DrawType {
  RANDOM
  ALGORITHM
}

enum DrawStatus {
  PENDING
  SIMULATED
  PUBLISHED
}

enum MatchType {
  FIVE_MATCH
  FOUR_MATCH
  THREE_MATCH
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

// ─── MODELS ────────────────────────────────────────────────────

model Profile {
  id                      String   @id @default(uuid()) @db.Uuid
  email                   String   @unique
  fullName                String?  @map("full_name")
  avatarUrl               String?  @map("avatar_url")
  role                    Role     @default(SUBSCRIBER)
  country                 String?  @default("GB")
  charityContributionPct  Int      @default(10) @map("charity_contribution_pct")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  // Relations
  charityId     String?       @map("charity_id") @db.Uuid
  charity       Charity?      @relation(fields: [charityId], references: [id])
  subscription  Subscription?
  scores        Score[]
  drawResults   DrawResult[]
  donations     Donation[]

  @@map("profiles")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  stripeCustomerId      String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?            @unique @map("stripe_subscription_id")
  plan                  SubscriptionPlan   @default(MONTHLY)
  status                SubscriptionStatus @default(PENDING)
  currentPeriodStart    DateTime?          @map("current_period_start")
  currentPeriodEnd      DateTime?          @map("current_period_end")
  cancelAtPeriodEnd     Boolean            @default(false) @map("cancel_at_period_end")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  // Relations
  userId  String  @unique @map("user_id") @db.Uuid
  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Score {
  id        String   @id @default(uuid()) @db.Uuid
  score     Int      // Stableford score: 1–45
  playedAt  DateTime @map("played_at") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userId  String  @map("user_id") @db.Uuid
  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
  @@map("scores")
}

model Charity {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String? @db.Text
  imageUrl    String? @map("image_url")
  websiteUrl  String? @map("website_url")
  isFeatured  Boolean @default(false) @map("is_featured")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  profiles      Profile[]
  contributions CharityContribution[]
  donations     Donation[]

  @@map("charities")
}

model Draw {
  id              String     @id @default(uuid()) @db.Uuid
  month           DateTime   @db.Date // First of month, e.g. 2026-03-01
  type            DrawType   @default(RANDOM)
  status          DrawStatus @default(PENDING)
  prizePoolTotal  Decimal    @default(0) @map("prize_pool_total") @db.Decimal(10, 2)
  jackpot5Match   Decimal    @default(0) @map("jackpot_5_match") @db.Decimal(10, 2)
  prize4Match     Decimal    @default(0) @map("prize_4_match") @db.Decimal(10, 2)
  prize3Match     Decimal    @default(0) @map("prize_3_match") @db.Decimal(10, 2)
  winningNumbers  Int[]      @default([]) @map("winning_numbers")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Jackpot rollover tracking (self-relation)
  rolloverFromId  String?    @unique @map("rollover_from_id") @db.Uuid
  rolloverFrom    Draw?      @relation("DrawRollover", fields: [rolloverFromId], references: [id])
  rolloverTo      Draw?      @relation("DrawRollover")

  // Relations
  results       DrawResult[]
  contributions CharityContribution[]

  @@unique([month])
  @@map("draws")
}

model DrawResult {
  id                  String             @id @default(uuid()) @db.Uuid
  matchType           MatchType          @map("match_type")
  prizeAmount         Decimal            @default(0) @map("prize_amount") @db.Decimal(10, 2)
  verificationStatus  VerificationStatus @default(PENDING) @map("verification_status")
  proofUrl            String?            @map("proof_url")
  paymentStatus       PaymentStatus      @default(PENDING) @map("payment_status")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  // Relations
  drawId  String  @map("draw_id") @db.Uuid
  draw    Draw    @relation(fields: [drawId], references: [id], onDelete: Cascade)
  userId  String  @map("user_id") @db.Uuid
  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([drawId])
  @@index([userId])
  @@map("draw_results")
}

model CharityContribution {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  drawId    String  @map("draw_id") @db.Uuid
  draw      Draw    @relation(fields: [drawId], references: [id], onDelete: Cascade)
  charityId String  @map("charity_id") @db.Uuid
  charity   Charity @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@index([drawId])
  @@index([charityId])
  @@map("charity_contributions")
}

model Donation {
  id        String   @id @default(uuid()) @db.Uuid
  amount    Decimal  @db.Decimal(10, 2)
  message   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userId    String  @map("user_id") @db.Uuid
  profile   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  charityId String  @map("charity_id") @db.Uuid
  charity   Charity @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([charityId])
  @@map("donations")
}
